# Plantilla de variables de entorno de dueo-server.
# Copia este archivo a `.env` y rellena los valores reales:
#     cp .env.example .env
# `.env` está en .gitignore (no se versiona). Este `.env.example` SÍ se versiona.

# --- Telegram -------------------------------------------------------------
# Token del bot que te da @BotFather (/newbot). Es de la INSTANCIA: un único bot
# para todo Dueo. Si lo dejas vacío, el canal de Telegram queda desactivado y el
# resto de la app funciona igual (las notificaciones in-app no dependen de esto).
DUEO_TELEGRAM_BOT_TOKEN=

# Nota: el destino (chat_id del grupo o privado) NO va aquí. Es configuración POR
# USUARIO y se guarda en la base de datos a través de la app
# (PUT /api/channels/telegram), porque Dueo es multi-cuenta.

# --- Red ------------------------------------------------------------------
# Dirección de escucha. Local: 127.0.0.1:3000 (por defecto). En contenedor o
# servidor accesible desde fuera, usa 0.0.0.0:3000.
DUEO_BIND=127.0.0.1:3000

# --- Seguridad ------------------------------------------------------------
# Auto-registro desde el login. Por defecto CERRADO: tras crear el admin del
# primer arranque, las cuentas las da de alta un administrador (Ajustes → Usuarios).
# Pon 1 para permitir que cualquiera se registre.
DUEO_OPEN_REGISTRATION=0

# Marca la cookie de sesión como Secure (solo viaja por HTTPS). Actívalo (=1) si
# sirves Dueo tras un proxy con TLS. En HTTP plano (LAN) déjalo en 0 o no entrarás.
DUEO_SECURE_COOKIE=0

# --- Email / SMTP ---------------------------------------------------------
# Canal de notificaciones por correo. Si dejas DUEO_SMTP_HOST/FROM vacíos, el canal
# de email queda desactivado y el resto de la app funciona igual. El DESTINO (a qué
# correo se envía) NO va aquí: lo configura cada usuario en Ajustes → Correo.
DUEO_SMTP_HOST=
DUEO_SMTP_PORT=587
DUEO_SMTP_USER=
DUEO_SMTP_PASS=
# Remitente: un email o "Dueo <noreply@tu-dominio>".
DUEO_SMTP_FROM=
